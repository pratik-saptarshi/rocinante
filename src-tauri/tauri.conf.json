{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rocinante Repo Analyzer",
  "version": "0.1.0",
  "identifier": "com.rocinante.repoanalyzer",
  "build": {
    "frontendDist": "../ui",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Rocinante Repo Analyzer",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  }
}
